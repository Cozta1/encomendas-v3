# =============================================
# Variaveis de Ambiente - Sistema de Encomendas
# =============================================
# Copie este ficheiro para .env e preencha os valores:
#   cp .env.example .env
#
# IMPORTANTE: Nunca commite o ficheiro .env no git!
# =============================================

# --- Banco de Dados ---
POSTGRES_DB=sistema_encomendas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SUA_SENHA_SEGURA_AQUI

# --- Perfil Spring ---
# O DataSeeder popula o banco automaticamente no primeiro boot (idempotente).
SPRING_PROFILES_ACTIVE=prod

# --- JWT (Seguranca) ---
# Gere uma chave forte com: openssl rand -base64 64
APP_JWT_SECRET=GERE_UMA_CHAVE_SECRETA_FORTE_AQUI

# --- Chaves de Registro ---
# Chaves que os utilizadores precisam informar ao se registrar
APP_REGISTRATION_KEY=SUA_CHAVE_USER_AQUI
APP_ADMIN_REGISTRATION_KEY=SUA_CHAVE_ADMIN_AQUI

# --- Email (Gmail SMTP) ---
# Para usar Gmail: ative "App Passwords" em https://myaccount.google.com/apppasswords
SPRING_MAIL_USERNAME=seu_email@gmail.com
SPRING_MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# --- Suporte ---
APP_SUPPORT_DEV_EMAIL=seu_email@gmail.com

# --- Porta do Sistema ---
# Mude se a porta 80 estiver ocupada (ex: IIS, Apache)
APP_PORT=8090

# =============================================
# Variaveis AWS (apenas para deploy na nuvem)
# =============================================
# Descomente e preencha ao usar SPRING_PROFILES_ACTIVE=aws
#
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=encomendas-uploads
#
# No App Runner, credenciais vem via IAM Role (sem access keys).
# Para teste local com perfil aws, configure AWS CLI:
#   aws configure
# =============================================